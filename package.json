{
  "name": "claude-code-mailer",
  "version": "2.1.2",
  "description": "Claude Code Mailer - Smart email notifications for Claude Code with automatic hooks installation and multilingual templates",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "claude-code-mailer": "dist/cli/index.js"
  },
  "scripts": {
    "build": "bun run build.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepublishOnly": "bun run typecheck && bun run build && bun test"
  },
  "keywords": [
    "claude",
    "claude-code",
    "email",
    "notification",
    "nodemailer",
    "smtp",
    "hooks",
    "automation",
    "multilingual",
    "cli"
  ],
  "author": "Benjamin Chris",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LuRenJiasWorld/Claude-Code-Mailer.git"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "js-yaml": "^4.1.0",
    "nodemailer": "^6.9.15"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^6.4.17",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "config/",
    "README.md",
    "README.zh.md",
    "LICENSE",
    ".env.template"
  ]
}
